# Google Analytics 4 — Measurement ID
# Ottieni l'ID da: analytics.google.com → Amministrazione → Flussi di dati → Web
# Formato: G-XXXXXXXXXX
PUBLIC_GA_ID=G-XXXXXXXXXX
