---
import { Button } from "@/components/ui/button";
---

<section id="preventivo" class="py-24 bg-primary text-primary-foreground relative overflow-hidden flex items-center justify-center scroll-mt-20">
	<div class="absolute top-0 right-0 w-96 h-96 bg-white/10 rounded-full blur-[80px] -translate-y-1/2 translate-x-1/2"></div>
	<div class="container mx-auto px-6 relative z-10">
		<div class="grid lg:grid-cols-2 gap-16 items-center">
			<div id="cta-content" class="text-left opacity-0 -translate-x-10">
				<h2 class="text-3xl font-bold md:text-6xl mb-8 font-heading leading-[1.1]">Pronto a rinnovare la <span class="text-secondary italic">tua casa?</span></h2>
				<p class="text-primary-foreground/90 text-lg md:text-xl mb-12 max-w-xl">
					Offriamo sopralluoghi gratuiti e consulenze personalizzate su Abbiategrasso e zone limitrofe. Il nostro esperto Stefano ti aiuterà a scegliere la soluzione migliore.
				</p>
				<div class="flex flex-col gap-4 text-sm font-medium">
					<div class="flex items-center gap-3">
						<div class="flex h-6 w-6 items-center justify-center rounded-full bg-white/20 text-white">✓</div>
						Sopraluogo gratuito per misurazioni
					</div>
					<div class="flex items-center gap-3">
						<div class="flex h-6 w-6 items-center justify-center rounded-full bg-white/20 text-white">✓</div>
						Preventivo trasparente e senza impegno
					</div>
					<div class="flex items-center gap-3">
						<div class="flex h-6 w-6 items-center justify-center rounded-full bg-white/20 text-white">✓</div>
						Installazione professionale inclusa
					</div>
				</div>
			</div>

			<div id="cta-form" class="bg-white dark:bg-card p-8 rounded-3xl shadow-2xl text-foreground opacity-0 translate-x-10 scale-95">
				<!-- Il modulo inoltrerà in automatico i dati alla mail specificata in action -->
				<form action="https://formsubmit.co/letendeadarte@gmail.com" method="POST" class="space-y-6">
					<input type="hidden" name="_subject" value="Nuova richiesta preventivo dal sito Web Le Tende ad Arte">
					<input type="hidden" name="_captcha" value="false">
					<input type="hidden" name="_template" value="box">
					<input type="hidden" name="_autoresponse" value="Grazie per la tua richiesta! Abbiamo ricevuto il tuo messaggio e ti contatteremo il prima possibile per studiare insieme la soluzione migliore. — Stefano, Le Tende ad Arte">
					<input type="hidden" name="_next" value="https://letendeadarte.it/">
					
					<div class="grid sm:grid-cols-2 gap-4">
						<div class="space-y-2">
							<label class="text-sm font-bold uppercase tracking-widest text-muted-foreground">Nome</label>
							<input type="text" name="nome" required class="w-full px-4 py-3 rounded-xl border border-border bg-secondary/20 focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all" />
						</div>
						<div class="space-y-2">
							<label class="text-sm font-bold uppercase tracking-widest text-muted-foreground">Cognome</label>
							<input type="text" name="cognome" required class="w-full px-4 py-3 rounded-xl border border-border bg-secondary/20 focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all" />
						</div>
					</div>
					<div class="grid sm:grid-cols-2 gap-4">
						<div class="space-y-2">
							<label class="text-sm font-bold uppercase tracking-widest text-muted-foreground">Email</label>
							<input type="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-border bg-secondary/20 focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all" />
						</div>
						<div class="space-y-2">
							<label class="text-sm font-bold uppercase tracking-widest text-muted-foreground">Telefono</label>
							<input type="tel" name="telefono" class="w-full px-4 py-3 rounded-xl border border-border bg-secondary/20 focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all" />
						</div>
					</div>
					<div class="space-y-2">
						<label class="text-sm font-bold uppercase tracking-widest text-muted-foreground">Messaggio</label>
						<textarea name="messaggio" rows="4" required class="w-full px-4 py-3 rounded-xl border border-border bg-secondary/20 focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all" placeholder="Descrivi il tuo progetto..."></textarea>
					</div>
					<div class="flex items-center gap-3 py-2">
						<input type="checkbox" required class="h-4 w-4 rounded border-gray-300 text-primary focus:ring-primary" id="privacy" />
						<label for="privacy" class="text-xs text-muted-foreground">Acconsento al trattamento dei dati personali (D.Lgs. 196/03)</label>
					</div>
					<Button type="submit" size="lg" className="w-full rounded-xl h-14 text-white font-bold text-lg shadow-xl hover:shadow-2xl transition-all">
						Invia la Richiesta
					</Button>
				</form>
			</div>
		</div>
	</div>
</section>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";
	gsap.registerPlugin(ScrollTrigger);

	document.addEventListener("astro:page-load", () => {
		if (!document.getElementById("preventivo")) return;

		// Content
		gsap.to("#cta-content", {
			scrollTrigger: {
				trigger: "#preventivo",
				start: "top 80%",
				toggleActions: "play none none none",
			},
			opacity: 1,
			x: 0,
			duration: 1.2,
			ease: "power3.out",
		});

		// Form
		gsap.to("#cta-form", {
			scrollTrigger: {
				trigger: "#preventivo",
				start: "top 70%",
				toggleActions: "play none none none",
			},
			opacity: 1,
			x: 0,
			scale: 1,
			duration: 1.5,
			ease: "elastic.out(1, 0.8)",
		});
	});
</script>
