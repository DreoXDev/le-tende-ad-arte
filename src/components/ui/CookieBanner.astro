---
import { Button } from "@/components/ui/button";
---

<div id="cookie-banner" class="fixed bottom-6 left-6 right-6 md:left-auto md:right-10 md:max-w-md z-[100] transform translate-y-20 opacity-0 invisible transition-all duration-500">
	<div class="bg-white dark:bg-card border border-border shadow-2xl rounded-2xl p-6 md:p-8">
		<div class="flex flex-col gap-4">
			<div class="space-y-2">
				<h3 class="font-bold text-lg font-heading">Cookie & Privacy</h3>
				<p class="text-sm text-muted-foreground leading-relaxed">
					Utilizziamo solo cookie tecnici necessari e analitici anonimi per garantirti la migliore esperienza. Leggi la nostra <a href="/privacy" class="text-primary hover:underline">Privacy Policy</a>.
				</p>
			</div>
			<div class="flex gap-3">
				<Button id="accept-cookies" size="sm" className="flex-1 rounded-xl font-bold cursor-pointer">
					Accetta
				</Button>
				<Button id="decline-cookies" variant="outline" size="sm" className="flex-1 rounded-xl cursor-pointer">
					Rifiuta
				</Button>
			</div>
		</div>
	</div>
</div>

<script>
	function initCookieBanner() {
		const banner = document.getElementById("cookie-banner");
		const acceptBtn = document.getElementById("accept-cookies");
		const declineBtn = document.getElementById("decline-cookies");

		if (!banner || !acceptBtn || !declineBtn) return;

		// Gestione Google Consent V2 helper
		function updateConsent(granted) {
			if (typeof window !== 'undefined' && typeof window.gtag === 'function') {
				window.gtag('consent', 'update', {
					'analytics_storage': granted ? 'granted' : 'denied'
				});
			}
		}

		// Check if already consented
		const currentConsent = localStorage.getItem("cookie-consent");
		if (!currentConsent) {
			setTimeout(() => {
				banner.classList.remove("invisible", "translate-y-20", "opacity-0");
			}, 2000);
		} else if (currentConsent === "accepted") {
			updateConsent(true);
		}

		acceptBtn.addEventListener("click", () => {
			localStorage.setItem("cookie-consent", "accepted");
			updateConsent(true);
			hideBanner();
		});

		declineBtn.addEventListener("click", () => {
			localStorage.setItem("cookie-consent", "declined");
			updateConsent(false);
			hideBanner();
		});

		function hideBanner() {
			banner!.classList.add("translate-y-20", "opacity-0");
			setTimeout(() => banner!.classList.add("invisible"), 500);
		}
	}

	// Re-init on page transitions
	initCookieBanner();
	document.addEventListener("astro:after-swap", initCookieBanner);
</script>
