---
import { Instagram, Facebook, MessageCircle } from "lucide-astro";
import { products } from "@/data/products";
import { asset, link } from "@/lib/asset";
---
<footer class="border-t py-20 bg-background">
	<div class="container mx-auto px-6">
		<div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8 mb-20">
			<!-- Brand Info -->
			<div class="lg:col-span-1">
				<div class="flex items-center gap-4 mb-8">
					<img src={asset("/images/logo.png")} alt="Le Tende ad Arte" class="h-12 w-12 object-contain dark:invert opacity-80" />
					<div class="text-2xl font-bold font-heading tracking-tighter uppercase leading-none mt-2">
						LE TENDE AD <br/><span class="text-primary italic">ARTE</span>
					</div>
				</div>
				<p class="text-muted-foreground text-sm leading-relaxed mb-8">
					Le Tende ad Arte di Garegnani Stefano. <br/>
					Esperienza artigianale nella realizzazione di tende su misura e rivestimenti dal 1970.
				</p>
				<div class="flex gap-4">
					<a href="https://www.instagram.com/letendeadarte/" target="_blank" class="h-10 w-10 window-social rounded-full bg-secondary flex items-center justify-center hover:bg-primary hover:text-white transition-all" aria-label="Instagram"><Instagram class="h-5 w-5" /></a>
					<a href="https://www.facebook.com/tendeadarte/" target="_blank" class="h-10 w-10 window-social rounded-full bg-secondary flex items-center justify-center hover:bg-primary hover:text-white transition-all" aria-label="Facebook"><Facebook class="h-5 w-5" /></a>
					<a href="https://wa.me/393462138048" target="_blank" class="h-10 w-10 window-social rounded-full bg-secondary flex items-center justify-center hover:bg-primary hover:text-white transition-all" aria-label="WhatsApp"><MessageCircle class="h-5 w-5" /></a>
				</div>
			</div>

			<!-- Quick Links -->
			<div>
				<h4 class="font-bold mb-6 uppercase text-sm tracking-[0.2em] text-foreground">Link Rapidi</h4>
				<ul class="space-y-4 text-sm text-muted-foreground font-medium">
					<li><a href={link("/#home")} class="hover:text-primary transition-colors">Home</a></li>
					<li><a href={link("/#metodo")} class="hover:text-primary transition-colors">Il Nostro Metodo</a></li>
					<li><a href={link("/#recensioni")} class="hover:text-primary transition-colors">Recensioni</a></li>
					<li><a href={link("/#preventivo")} class="hover:text-primary transition-colors">Richiedi Preventivo</a></li>
				</ul>
			</div>

			<!-- Products -->
			<div>
				<h4 class="font-bold mb-6 uppercase text-sm tracking-[0.2em] text-foreground">I Nostri Prodotti</h4>
				<ul class="space-y-4 text-sm text-muted-foreground font-medium">
					{products.map((p) => (
						<li>
							<a href={link(`/prodotti/${p.slug}`)} class="hover:text-primary transition-colors">
								{p.title}
							</a>
						</li>
					))}
				</ul>
			</div>

			<!-- Contact -->
			<div>
				<h4 class="font-bold mb-6 uppercase text-sm tracking-[0.2em] text-foreground">Contatti</h4>
				<ul class="space-y-4 text-sm text-muted-foreground font-medium">
					<li class="flex items-start gap-3">Via XX Settembre, 12<br/>20081 Abbiategrasso (MI)</li>
					<li><a href="tel:+390294969152" class="hover:text-primary transition-colors">02 94969152</a></li>
					<li><a href="tel:+393462138048" class="hover:text-primary transition-colors">346 2138048</a></li>
					<li><a href="mailto:letendeadarte@gmail.com" class="hover:text-primary transition-colors break-all">letendeadarte@gmail.com</a></li>
				</ul>
			</div>
		</div>
		
		<div class="border-t pt-10 flex flex-col md:flex-row justify-between items-center gap-4 text-center md:text-left">
			<p class="text-muted-foreground text-sm font-medium">© 2026 Le Tende ad Arte - P.IVA 11522420964.</p>
			<div class="flex gap-4 text-sm font-medium">
				<a href={link("/privacy")} class="text-muted-foreground hover:text-primary transition-colors">Privacy Policy</a>
				<span class="text-muted-foreground/30">|</span>
				<a href={link("/privacy")} class="text-muted-foreground hover:text-primary transition-colors">Cookie Policy</a>
			</div>
		</div>
	</div>
</footer>
